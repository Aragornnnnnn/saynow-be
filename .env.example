# 로컬 개발은 이 파일을 .env로 복사한 뒤 값을 채워 사용한다.
SPRING_PROFILES_ACTIVE=local

# local 프로필 기본값이다. 환경에 맞게 바꿔도 된다.
DB_URL=jdbc:postgresql://localhost:5432/postgres
DB_USERNAME=postgres
DB_PASSWORD=postgres

# 운영 값과 다른 로컬 개발용 secret을 사용한다.
SAYNOW_AUTH_TOKEN_SECRET=<local-dev-token-secret>

# Google Web OAuth Client ID 또는 앱 플랫폼별 Client ID를 comma-separated로 입력한다.
SAYNOW_AUTH_OIDC_GOOGLE_AUDIENCES=<google-client-id>

# Kakao OIDC를 쓰지 않으면 비워 둔다.
SAYNOW_AUTH_OIDC_KAKAO_AUDIENCES=

# local 또는 remote.
SAYNOW_AI_CLIENT_MODE=local

# Sentry를 로컬에서 테스트해야 할 때만 true로 바꾼다.
SENTRY_ENABLED=false
SENTRY_DSN=https://<public-key>@<org>.ingest.sentry.io/<project-id>
SENTRY_ENVIRONMENT=local
SENTRY_LOGS_ENABLED=false
SENTRY_RELEASE=saynow-be
